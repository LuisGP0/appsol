# Copia este fichero como .env y rellena los valores

# Clave API de Anthropic (obligatorio)
# Consíguela en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX

# Clave API de Google PageSpeed Insights (opcional, mejora el análisis)
# Consíguela en https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Orígenes permitidos para CORS (separados por coma)
# En producción pon tu dominio: https://solpronet.cat
ALLOWED_ORIGINS=http://localhost:3000,https://solpronet.cat

# Puerto del servidor
PORT=3000
